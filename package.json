{
  "name": "github-contributions-ui",
  "version": "1.0.18",
  "description": "GitHub contributions graph React component",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/styles.css",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && npm run build:css",
    "build:css": "npx tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "publish-package": "npm run build && npm publish --access public"
  },
  "keywords": [
    "github",
    "github contributions",
    "react component",
    "github graph",
    "heatmap",
    "portfolio",
    "nextjs",
    "opensource"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bichitrabehera/github-contributions-ui.git"
  },
  "homepage": "https://github.com/bichitrabehera/github-contributions-ui#readme",
  "bugs": {
    "url": "https://github.com/bichitrabehera/github-contributions-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^18.0.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
