{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,

    "isolatedModules": true,
    "resolveJsonModule": true,

    "declaration": true,
    "noEmit": true
  },
  "include": ["src"]
}